<Application
    x:Class="Quark.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Quark.Converters"
    xmlns:local="clr-namespace:Quark"
    xmlns:Theme="clr-namespace:CapriciousUI.Wpf;assembly=CapriciousUI.Wpf"
    StartupUri="Views/MainWindow.xaml"
    Theme:ThemeManager.Theme="Light">
    <Application.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityCollapseConverter" />
        <conv:TimeSpanToMillisecondConverter x:Key="TimeSpanToMillisecondConverter" />

        <FontFamily x:Key="UIFont">Meiryo</FontFamily>
    </Application.Resources>
</Application>
